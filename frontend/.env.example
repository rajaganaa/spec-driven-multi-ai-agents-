# frontend/.env.example — copy to frontend/.env before building.
# Vite inlines VITE_-prefixed vars into the bundle at BUILD time, not
# runtime — changing this after `npm run build` has no effect on the
# already-built dist/ until you rebuild.

# Local dev (matches `uvicorn api:app --port 8080` run locally)
VITE_API_URL=http://localhost:8080

# Production — set to your deployed Cloud Run URL before building for
# GitHub Pages deploy (see .github/workflows/deploy-frontend.yml, which
# reads this from a repo secret instead of this file in CI).
# VITE_API_URL=https://your-cloud-run-url.run.app
