# # my-agent-hub — environment template
# # Copy to .env and fill in real values. NEVER commit the real .env —
# # it's already in .gitignore (see below). This file should only ever
# # contain placeholders.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=project-f3ec0b47-4580-4493-a79
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=E:/password/GCP_medical-azure-key.json






# # ── Primary — self-hosted vLLM on AWS EC2 (Part 1) ─────────────────────
# # Leave VLLM_BASE_URL unset/empty to disable the router entirely and
# # use Gemini for everything, exactly like before this upgrade.
# VLLM_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8000/v1
# # Must match the --api-key the vLLM server was started with
# # (deploy/aws/02_setup_vllm.sh requires you to set this explicitly —
# # there is no default baked into the code).
# VLLM_API_KEY=choose-a-real-secret-do-not-reuse-this-value
# VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# # ── Fallback — GCP Vertex AI Gemini (used automatically whenever the
# #    vLLM health check fails, or always if VLLM_BASE_URL is unset) ────
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# # Path to a service-account JSON key, OR — strongly preferred for
# # anything beyond local dev — omit this entirely and use Application
# # Default Credentials / Workload Identity / a mounted Cloud Run Secret
# # instead. Never commit the key file itself, and never put it under a
# # path you'd paste into a chat or a public repo.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# # ── FastAPI backend (api.py) ────────────────────────────────────────────
# # Comma-separated list of allowed frontend origins. Required in
# # production — api.py logs a loud warning and falls back to "*" (every
# # origin) if this is unset.
# FRONTEND_ORIGIN=https://your-username.github.io

# # ── React frontend (Part 5) ─────────────────────────────────────────────
# # Set in frontend/.env (Vite reads VITE_-prefixed vars at build time,
# # not at runtime) — see frontend/.env.example.
# VITE_API_URL=https://your-cloud-run-url.run.app


# Vertex AI with your GCP service account
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=project-f3ec0b47-4580-4493-a79
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=E:/password/GCP_medical-azure-key.json

# Frontend
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:8080