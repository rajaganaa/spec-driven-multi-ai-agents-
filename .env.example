# my-agent-hub — environment template
# Copy this to .env and fill in real values. NEVER commit the real .env —
# it's already in .gitignore. This file must only ever contain placeholders.

# Primary — self-hosted vLLM on AWS EC2 (optional)
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# Fallback — GCP Vertex AI Gemini
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Alternative — Google AI Studio API key (simplest local setup)
# GOOGLE_API_KEY=your-api-key-here

# FastAPI backend (api.py)
FRONTEND_ORIGIN=http://localhost:5173

# React frontend (Vite)
VITE_API_URL=http://localhost:8080
